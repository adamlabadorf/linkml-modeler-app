{
  "name": "@linkml-editor/electron",
  "version": "0.1.3",
  "description": "LinkML Modeler desktop application",
  "author": {
    "name": "Adam Labadorf",
    "email": "adam@linkml.io"
  },
  "homepage": "https://github.com/adamlabadorf/linkml-modeler-app",
  "repository": {
    "type": "git",
    "url": "https://github.com/adamlabadorf/linkml-modeler-app.git"
  },
  "type": "commonjs",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "echo 'No electron tests yet' && exit 0",
    "package": "pnpm --filter @linkml-editor/web build:electron && pnpm run build && electron-builder --publish never",
    "package:linux": "pnpm --filter @linkml-editor/web build:electron && pnpm run build && electron-builder --linux --publish never",
    "package:mac": "pnpm --filter @linkml-editor/web build:electron && pnpm run build && electron-builder --mac --publish never",
    "package:win": "pnpm --filter @linkml-editor/web build:electron && pnpm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@linkml-editor/core": "workspace:*",
    "isomorphic-git": "^1.27.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "build": {
    "appId": "io.linkml.modeler",
    "productName": "LinkML Modeler",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Science",
      "icon": "build/icons"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icons/icon.ico"
    }
  }
}
